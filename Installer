#!/bin/zsh
clear

M_ROOT="$HOME/.vault_system"
P_ZONE="$HOME/Library/Caches/.apple_tcc_cache"
L_FILE="$HOME/Library/Logs/audit_info.log"

if [[ -d "$M_ROOT" ]]; then
  printf "Vault system exists. Reset? [y/N]: "
  read -r reset
  if [[ "$reset" =~ ^[Yy] ]]; then
    rm -rf -- "$M_ROOT" "$P_ZONE"
  else
    printf "Aborted.\n"
    exit 0
  fi
fi

printf "SET PIN 1: " ; read -r p1
printf "SET PIN 2: " ; read -r p2
printf "SET MASTER: " ; read -r p3
printf "SET PANIC PIN: " ; read -r panic

mkdir -p -- "$M_ROOT" "$P_ZONE"

for i in {1..500}; do
  mkdir -p -- "$M_ROOT/x$(jot -r 1 100000 999999)"
done

R_DIR="$M_ROOT/x$(jot -r 1 100000 999999)"
mkdir -p -- "$R_DIR"
printf "VAULT CONTENTS\n================\n\n" > "$R_DIR/vault.txt"
printf "%s\n%s\n%s\n%s\n" "$p1" "$p2" "$p3" "$panic" > "$R_DIR/.data"

cat << 'EOF' > "$HOME/OpenSafe.sh"
#!/bin/zsh

D_FILE=$(find "$HOME/.vault_system" -name ".data" 2>/dev/null | head -n 1)
if [[ -z "$D_FILE" ]]; then
  echo "Config not found. Re-run installer."
  exit 1
fi

V_DIR=$(dirname "$D_FILE")
CFG=($(cat "$D_FILE"))
P1=${CFG[1]}; P2=${CFG[2]}; P3=${CFG[3]}; PANIC=${CFG[4]}

P_ZONE="$HOME/Library/Caches/.apple_tcc_cache"
L_FILE="$HOME/Library/Logs/audit_info.log"
K1=0; K2=0; K3=0
R='\033[1;31m'; G='\033[1;32m'; Y='\033[1;33m'; B='\033[1;34m'; NC='\033[0m'

trap 'echo "Cannot quit this way"; sleep 1' INT TERM HUP

self_repair() {
  [[ ! -x "$HOME/OpenSafe.sh" ]] && chmod +x "$HOME/OpenSafe.sh"
  [[ ! -f "$HOME/.vault_system" ]] && echo "Vault lost - reinstall required"
}

while true; do
  self_repair
  clear
  printf "${B}+-------------------------------------------+\n"
  printf "|                  [ SAFE ]                 |\n"
  printf "+-------------------------------------------+${NC}\n"
  printf "${B}|                                           |\n"
  printf "|     #################################     |\n"
  printf "|     #                               #     |\n"
  if [[ $K1 -eq 1 && $K2 -eq 1 && $K3 -eq 1 ]]; then
    printf "|     #${G}            UNLOCKED           ${B}#     |\n"
  else
    printf "|     #${R}             LOCKED            ${B}#     |\n"
  fi
  printf "|     #            [  O  ]            #     |\n"
  printf "|     #################################     |\n"
  printf "|                                           |\n"
  printf "+-------------------------------------------+${NC}\n"
  printf "\n   "
  [[ $K1 -eq 1 ]] && printf "${G}[OK] 1 ${NC}" || printf "${R}[X] 1 ${NC}"
  [[ $K2 -eq 1 ]] && printf "${G}[OK] 2 ${NC}" || printf "${R}[X] 2 ${NC}"
  [[ $K1 -eq 1 && $K2 -eq 1 ]] && printf "${Y} [!] MASTER READY${NC}"
  printf "\n\n   [D] DEPOSIT  [Q] QUIT  [1-3] PINS"
  [[ $K1 -eq 1 && $K2 -eq 1 ]] && printf "  MASTER"
  printf "\n   INPUT > "
  read -k 1 c
  echo
  case $c in
  1) printf "\n PIN 1: "; read -s p; echo
     if [[ "$p" == "$PANIC" ]]; then
       mv "$V_DIR"/* "$P_ZONE/" 2>/dev/null
       mv "$HOME/OpenSafe.sh" "$P_ZONE/" 2>/dev/null || true
       printf "[$(date)] PANIC_TRIGGERED\n" >> "$L_FILE"
       exit
     fi
     [[ "$p" == "$P1" ]] && K1=1 ;;
  2) printf "\n PIN 2: "; read -s p; echo; [[ "$p" == "$P2" ]] && K2=1 ;;
  3) if [[ $K1 -eq 1 && $K2 -eq 1 ]]; then
       printf "\n MASTER: "; read -s p; echo; [[ "$p" == "$P3" ]] && K3=1
     fi ;;
  [dD]) printf "\n PATH: "; read f; f=${f//\'/}; [[ -e "$f" ]] && mv "$f" "$V_DIR" 2>/dev/null && sleep 1 ;;
  [qQ]) printf "Stay safe.\n"; sleep 1 ;;
  esac
  if [[ $K1 -eq 1 && $K2 -eq 1 && $K3 -eq 1 ]]; then
    for i in {1..16}; do
      case $((i % 4)) in 0) H="/" ;; 1) H="-" ;; 2) H="\\" ;; 3) H="|" ;; esac
      clear; printf "       >>> DECOMPRESSING... %s\n" "$H"; sleep 0.05
    done
    chmod 600 "$HOME/OpenSafe.sh" 2>/dev/null || true
    open "$V_DIR"; K1=0; K2=0; K3=0; sleep 1
  fi
done
EOF

chmod +x "$HOME/OpenSafe.sh"
printf "\n✅ INSTALL COMPLETE. Run: ~/OpenSafe.sh\n"
